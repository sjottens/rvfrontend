# Gmail account that will send the contact form emails
GMAIL_USER=info@rvfrontend.nl

# Gmail app password (NOT your normal Gmail password)
# Create at: Google Account > Security > 2-Step Verification > App passwords
GMAIL_APP_PASSWORD=your-16-char-app-password

# Optional: where contact emails should arrive
# If empty, it will default to GMAIL_USER
CONTACT_TO_EMAIL=info@rvfrontend.nl
